rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to get the current user's data (costs a read)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Function to check if user is an admin
    function isAdmin() {
      let role = getUserData().role;
      return role == 'ADMIN_RT_RW' || role == 'ADMIN_KELURAHAN';
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only the user can create/update their own profile
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /reports/{reportId} {
      // Assumption: Allowing all authenticated users to read reports for simplicity.
      // Strict area-based reading would require additional checks or custom claims.
      allow read: if isAuthenticated();
      
      // User can create report if reporterId matches their uid
      allow create: if isAuthenticated() 
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.upvoteCount == 0
                    && request.resource.data.status == 'NEW';
      
      // Update rules
      allow update: if isAuthenticated() && (
        // Case 1: Admin updating status
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'resolvedAt']))
        ||
        // Case 2: System/User upvoting (upvoteCount changes)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvoteCount']))
      );
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /upvotes/{upvoteId} {
      allow read: if isAuthenticated();
      // upvoteId must be userId_reportId
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && upvoteId == (request.auth.uid + "_" + request.resource.data.reportId);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /areas/{areaId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only manageable from backend/console
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Creation usually done by Cloud Functions
      allow create: if false;
    }
  }
}
